  "item": [
    {
      "name": "Create User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.collectionVariables.get('timestamp')) {",
              "    pm.collectionVariables.set('timestamp', Date.now());",
              "}",
              "const timestamp = pm.collectionVariables.get('timestamp');",
              "pm.request.body.raw = pm.request.body.raw.replace(/{{timestamp}}/g, timestamp);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "const data = pm.response.json();",
              "pm.test(\"User id is set\", function () {",
              "    pm.expect(data.id).to.be.a('number');",
              "});",
              "pm.collectionVariables.set('userId', data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test-user-{{timestamp}}@example.com\",\n  \"name\": \"Postman User\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "users"
          ]
        }
      },
      "response": []
    },
